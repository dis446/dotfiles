{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "$note": "Claude Code keybindings, tuned for Pi-agent (pi/agent/keybindings.json) parity and for running inside zellij. PI PARITY: ctrl+e=external editor, ctrl+k=toggle thinking, shift+enter=newline, ctrl+v=paste image, ctrl+-=undo, enter=submit, ctrl+d=exit, escape=cancel. NOTE: ctrl+e and ctrl+k shadow native readline end-of-line / delete-to-line-end in the input (this matches Pi's overload). Readline editing (ctrl+a/b/f/w/u/y, alt+b/f/d, arrows) is built into Claude's input and works without config. ZELLIJ: in normal mode zellij grabs ctrl+t/o/s/b/g/p/n; toggleTodos/toggleTranscript/stash moved to ctrl+shift+t/r/s to survive. No Claude equivalent for Pi's session mgmt (path/sort/filter/rename/delete), model cycling, message followUp/dequeue, or tree fold. User bindings are ADDITIVE: to change a default, set the old key to null AND add the new binding.",
  "bindings": [
    {
      "context": "Global",
      "bindings": {
        "ctrl+t": null,
        "ctrl+shift+t": "app:toggleTodos",
        "ctrl+o": null,
        "ctrl+shift+r": "app:toggleTranscript",
        "ctrl+shift+b": "app:toggleBrief",
        "ctrl+shift+o": "app:toggleTeammatePreview",
        "ctrl+]": "app:openArtifact",
        "ctrl+r": "history:search"
      }
    },
    {
      "context": "Chat",
      "bindings": {
        "up": "history:previous",
        "down": "history:next",
        "escape": "chat:cancel",
        "ctrl+x ctrl+k": "chat:killAgents",
        "shift+tab": "chat:cycleMode",
        "ctrl+l": "chat:modelPicker",
        "meta+o": "chat:fastMode",
        "meta+t": "chat:thinkingToggle",
        "meta+w": "chat:workflowKeywordToggle",
        "enter": "chat:submit",
        "shift+enter": "chat:newline",
        "ctrl+j": "chat:newline",
        "ctrl+-": "chat:undo",
        "ctrl+_": "chat:undo",
        "ctrl+e": "chat:externalEditor",
        "ctrl+x ctrl+e": "chat:externalEditor",
        "ctrl+g": "chat:externalEditor",
        "ctrl+k": "chat:thinkingToggle",
        "ctrl+s": null,
        "ctrl+shift+s": "chat:stash",
        "ctrl+v": "chat:imagePaste",
        "cmd+k": "chat:clearScreen"
      }
    },
    {
      "context": "Autocomplete",
      "bindings": {
        "tab": "autocomplete:accept",
        "escape": "autocomplete:dismiss",
        "up": "autocomplete:previous",
        "down": "autocomplete:next"
      }
    },
    {
      "context": "Confirmation",
      "bindings": {
        "y": "confirm:yes",
        "enter": "confirm:yes",
        "up": "confirm:previous",
        "down": "confirm:next",
        "tab": "confirm:nextField",
        "shift+tab": "confirm:cycleMode",
        "space": "confirm:toggle",
        "ctrl+e": "confirm:toggleExplanation"
      }
    },
    {
      "context": "Transcript",
      "bindings": {
        "ctrl+e": "transcript:toggleShowAll",
        "escape": "transcript:exit",
        "q": "transcript:exit"
      }
    },
    {
      "context": "Task",
      "bindings": {
        "ctrl+x ctrl+b": "task:background",
        "ctrl+b": "task:background"
      }
    }
  ]
}
