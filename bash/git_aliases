# Git basics
alias gita="git add"
alias gitc="git commit -sm"
alias gits="git status"
alias gitpull="git pull"
alias gitpush="git push"
alias gitl="git log"
alias gitd="git diff"
alias lg="lazygit"
alias gwt="git worktree"
alias gwtl="git worktree list"
alias gwtr="git worktree remove"

function gwts() {
  local target_branch="${1:-test}"
  local source_branch="${2:-$(git branch --show-current)}"
  local repo_root worktree_path tmpdir target_ref

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "gwts: not inside a git repository"
    return 1
  fi

  if [[ -z "$source_branch" ]]; then
    echo "gwts: could not determine source branch"
    return 1
  fi

  if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "gwts: working tree must be clean"
    return 1
  fi

  if ! git show-ref --verify --quiet "refs/heads/$target_branch"; then
    echo "gwts: local branch '$target_branch' does not exist"
    return 1
  fi

  repo_root="$(git rev-parse --show-toplevel)"
  target_ref="refs/heads/$target_branch"
  worktree_path="$(git -C "$repo_root" worktree list --porcelain | awk -v ref="$target_ref" '
    $1 == "worktree" { path = $2 }
    $1 == "branch" && $2 == ref { print path; exit }
  ')"

  if [[ -n "$worktree_path" ]]; then
    if [[ "$worktree_path" == "$repo_root" ]]; then
      echo "gwts: '$target_branch' is currently checked out in this worktree; switch off it first"
      return 1
    fi
  else
    tmpdir="$(mktemp -d)"
    worktree_path="$tmpdir"

    cleanup() {
      git -C "$repo_root" worktree remove --force "$tmpdir" >/dev/null 2>&1 || true
      rm -rf "$tmpdir"
    }
    trap cleanup RETURN

    if ! git -C "$repo_root" worktree add "$worktree_path" "$target_branch" >/dev/null; then
      echo "gwts: failed to create a worktree for '$target_branch'"
      return 1
    fi
  fi

  if ! git -C "$worktree_path" merge --squash "$source_branch"; then
    return 1
  fi

  if ! git -C "$worktree_path" commit -m "squash: $source_branch into $target_branch"; then
    return 1
  fi

  echo "Merged $source_branch into $target_branch locally."
}

alias gitsq="gwts"


# Git worktree helpers
# These keep worktrees in a sibling directory next to the main repo checkout,
# which matches the layout IntelliJ can natively detect and manage.

# Return the top-level directory of the current Git repository.
# Used internally so the worktree helpers can create paths relative to the
# repository you are currently inside.
__dotfiles_git_root() {
  command git rev-parse --show-toplevel 2>/dev/null
}

# Make a branch/ref name safe for filesystem paths.
# Replaces slashes and spaces with hyphens.
__dotfiles_sanitize() {
  printf '%s' "$1" | tr '/ ' '--'
}

# Resolve the directory under which worktrees should be created.
# Default is repo-sibling layout: <repo-parent>, so a repo named
#   relation-store
# gets a worktree like
#   relation-store-reporting
# If WORKTREE_ROOT is set, it overrides the default root.
__dotfiles_worktree_root() {
  local repo_root worktree_root
  repo_root="$1"
  worktree_root="${WORKTREE_ROOT:-}"

  if [ -n "$worktree_root" ]; then
    case "$worktree_root" in
      /*) printf '%s' "$worktree_root" ;;
      *) printf '%s/%s' "$repo_root" "$worktree_root" ;;
    esac
  else
    printf '%s' "$(dirname "$repo_root")"
  fi
}

# List all worktrees for the current repository.
# Use this to see which branches are attached to which directories.
gwtl() {
  command git worktree list
}

# Prune stale worktree metadata from the current repository.
# Run this after deleting a worktree directory manually.
gwtp() {
  command git worktree prune
}

# Create a new worktree for a new branch.
# Usage: gwtc <branch> [start-point]
# Creates the worktree beside the main checkout using IntelliJ-friendly naming:
#   <repo-parent>/<repo-name>-<branch>
# Then creates a new branch at the optional start-point.
gwtc() {
  local branch start_point repo_root repo_name worktree_root safe_branch worktree_dir
  branch="${1:?usage: gwtc <branch> [start-point]}"
  start_point="${2:-HEAD}"

  repo_root="$(__dotfiles_git_root)" || {
    printf 'gwtc: not in a git repo\n' >&2
    return 1
  }

  repo_name="$(basename "$repo_root")"
  worktree_root="$(__dotfiles_worktree_root "$repo_root")"
  safe_branch="$(__dotfiles_sanitize "$branch")"
  worktree_dir="${worktree_root}/${repo_name}-${safe_branch}"

  command mkdir -p "$worktree_root" && command git worktree add -b "$branch" "$worktree_dir" "$start_point"
}

# Create a worktree from an existing branch or ref.
# Usage: gwtb <branch-or-ref> [path]
# By default the worktree is created beside the main checkout as:
#   <repo-parent>/<repo-name>-<ref>
# Pass an explicit path if you want to place it somewhere else.
gwtb() {
  local ref repo_root repo_name worktree_root safe_ref worktree_dir
  ref="${1:?usage: gwtb <branch-or-ref> [path]}"

  repo_root="$(__dotfiles_git_root)" || {
    printf 'gwtb: not in a git repo\n' >&2
    return 1
  }

  repo_name="$(basename "$repo_root")"
  worktree_root="$(__dotfiles_worktree_root "$repo_root")"
  safe_ref="$(__dotfiles_sanitize "$ref")"
  worktree_dir="${2:-${worktree_root}/${repo_name}-${safe_ref}}"

  command mkdir -p "$worktree_root" && command git worktree add "$worktree_dir" "$ref"
}
