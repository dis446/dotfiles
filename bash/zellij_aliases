alias z="zellij attach work || zellij --session work"

function zwt() {
  local name="${1:-}"
  local repo_root repo_name worktree_dir tab_name

  if [[ -z "$name" ]]; then
    echo "usage: zwt <name>"
    return 1
  fi

  if [[ -z "${ZELLIJ:-}" ]]; then
    echo "zwt: run this from inside a zellij session"
    return 1
  fi

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "zwt: not inside a git repository"
    return 1
  fi

  repo_root="$(git rev-parse --show-toplevel)"
  repo_name="$(basename "$repo_root")"
  tab_name="$repo_name-$name"
  worktree_dir="$repo_root/.worktrees/$name"

  if [[ -e "$worktree_dir" ]]; then
    echo "zwt: worktree directory already exists: $worktree_dir"
    return 1
  fi

  if git show-ref --verify --quiet "refs/heads/$name"; then
    echo "zwt: branch '$name' already exists"
    return 1
  fi

  mkdir -p "$repo_root/.worktrees"

  if ! git -C "$repo_root" worktree add -b "$name" "$worktree_dir" >/dev/null; then
    echo "zwt: failed to create worktree and branch '$name'"
    return 1
  fi

  if ! zellij action new-tab --name "$tab_name" --cwd "$worktree_dir"; then
    git -C "$repo_root" worktree remove --force "$worktree_dir" >/dev/null 2>&1 || true
    return 1
  fi

  if ! zellij run --in-place --cwd "$worktree_dir" -- bash; then
    git -C "$repo_root" worktree remove --force "$worktree_dir" >/dev/null 2>&1 || true
    return 1
  fi

  zellij action new-pane --direction right --cwd "$worktree_dir" -- pi
}

function zwdone() {
  local current_worktree current_branch repo_root

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "zwdone: not inside a git repository"
    return 1
  fi

  current_worktree="$(git rev-parse --show-toplevel)"
  current_branch="$(git branch --show-current)"
  repo_root="$(git rev-parse --path-format=absolute --git-common-dir)"
  repo_root="$(dirname "$repo_root")"

  if ! gwts "$@"; then
    return 1
  fi

  if ! git -C "$repo_root" worktree remove --force "$current_worktree"; then
    echo "zwdone: failed to remove worktree '$current_worktree'"
    return 1
  fi

  git -C "$repo_root" worktree prune >/dev/null 2>&1 || true

  if [[ -n "$current_branch" ]]; then
    if ! git -C "$repo_root" branch -D "$current_branch"; then
      echo "zwdone: failed to delete branch '$current_branch'"
      return 1
    fi
  fi

  if [[ -n "${ZELLIJ:-}" ]]; then
    zellij action close-tab
  fi
}

alias zwd="zwdone"
